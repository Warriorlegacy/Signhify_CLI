{
  "name": "signhify",
  "version": "0.1.1",
  "private": true,
  "description": "An open-source AI engineering partner — in the terminal and in the IDE",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "npm run build -w packages/core",
    "build:providers": "npm run build -w packages/providers",
    "build:tools": "npm run build -w packages/tools",
    "build:memory": "npm run build -w packages/memory",
    "build:cli": "npm run build -w packages/cli",
    "build:vscode": "npm run build -w packages/vscode-ext",
    "test": "npm run test --workspaces --if-present",
    "test:core": "npm run test -w packages/core",
    "test:providers": "npm run test -w packages/providers",
    "test:tools": "npm run test -w packages/tools",
    "test:memory": "npm run test -w packages/memory",
    "test:cli": "npm run test -w packages/cli",
    "lint": "eslint packages/*/src/**/*.ts",
    "typecheck": "npm run typecheck -w packages/core -w packages/providers -w packages/tools -w packages/memory -w packages/cli",
    "clean": "npm run clean --workspaces --if-present",
    "clean:all": "node -e \"const {rmSync,existsSync}=require('fs');['dist','*.tsbuildinfo','.turbo','coverage'].forEach(p=>{if(existsSync(p))rmSync(p,{recursive:true,force:true})})\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
